<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Absulate-property-practice</title>
    <style>
        .div-1 {
            position:
                relative;
        }

        .div-1-btn-1 {
            position: absolute;
            background-color: black;
            border-radius: 50%;
            color: white;
            padding: 3px 4px 3px 4px;
            top: 0;
            right: 0;

        }

        .div-1-element2 {
            background-color: gray;
            position: absolute;
            background-color: gainsboro;
            width: 280px;
            height: 130px;
            top: 30px;
            right: 0px;

        }

        .div-1-element3 {
            background-color: gray;
            position: absolute;
            background-color: gainsboro;
            width: 280px;
            height: 130px;
            top: 300px;
            right: 0px;

        }

        .div-1-btn-2 {
            position: absolute;
            background-color: black;
            border-radius: 50%;
            color: white;
            padding: 3px 4px 3px 4px;
            top: -10px;
            left: -10px;

        }

        .div-1-element4 {
            background-color: gray;
            position: absolute;
            background-color: gainsboro;
            width: 280px;
            height: 130px;
            top: 630px;
            right: 0px;

        }

        .div-1-btn-3 {
            position: absolute;
            background-color: black;
            border-radius: 50%;
            color: white;
            padding: 3px 4px 3px 4px;
            top: -10px;
            left: -10px;
        }
        .time{
            background-color: black;
            color:white;
            position: absolute;
            right: 5px;
            bottom: 10px;
        }
        .div-2{
            background-color: rgb(207, 204, 204);
            position:relative;
            width: 300px;
            height: 300px;


        }
        .shirt{
            width: 280px;
            height: 280px;
            

        }
        .offer{
            background-color: black;
            color:white;
            position: absolute;
            right: 5px;
            top:10px;
            padding:5px 10px 5px 10px

        }
        .div-3{
            background-color: rgb(207, 204, 204);
            position:relative;
            width: 300px;
            height: 300px;
            top:50px;


        }
        .top{
            width: 200px;
            height: 200px;
            position: absolute;
        
        }button{
            position: absolute;
            bottom: 50px;
            left:40%;
        }
        button:hover{
            background-color: gray;
        }
    </style>
</head>

<body>
    <div class="div-1">
        <div class="div-1-btn-1">X</div>
        <div class="div-1-element2">

        </div>
        <div class="div-1-element3">
            <div class="div-1-btn-2">X</div>

        </div>
        <div class="div-1-element4">
            <div class="div-1-btn-3">X</div>
            <div class="time"> 20:20</div>

        </div>
    </div>
    <div>
        <div class="div-2">
            <img src="Google_2015_logo.svg.webp" alt="" class="shirt">
            <div class="offer"> 20% OFF</div>

    </div>
    <div>
        <div class="div-3">
            <img src="OIP.webp" alt="" class="top ">
            <div class="offer"> 20% OFF</div>
            <button>Add to cart</button>

    </div>

</body>

</html>
